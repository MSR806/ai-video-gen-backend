      "operation_key": "text_to_video",
      "operation_type": "text_to_video",
      "operation_name": "Text to Video",
      "endpoint_id": "fal-ai/veo3.1",
      "input_schema": {
        "type": "object",
        "required": [
          "prompt"
        ],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "The text prompt describing the video you want to generate."
          },
          "aspect_ratio": {
            "type": "string",
            "enum": [
              "16:9",
              "9:16"
            ],
            "default": "16:9",
            "description": "Aspect ratio of the generated video."
          },
          "duration": {
            "type": "string",
            "enum": [
              "4s",
              "6s",
              "8s"
            ],
            "default": "8s",
            "description": "The duration of the generated video."
          },
          "negative_prompt": {
            "x_ui_group": "advanced",
            "type": "string",
            "description": "A negative prompt to guide the video generation."
          },
          "resolution": {
            "type": "string",
            "enum": [
              "720p",
              "1080p",
              "4k"
            ],
            "default": "720p",
            "description": "The resolution of the generated video."
          },
          "generate_audio": {
            "type": "boolean",
            "default": true,
            "description": "Whether to generate audio for the video."
          },
          "seed": {
            "x_ui_group": "advanced",
            "type": "integer",
            "description": "The seed for the random number generator."
          },
          "auto_fix": {
            "x_ui_group": "advanced",
            "type": "boolean",
            "default": true,
            "description": "Whether to automatically attempt to fix prompts that fail content policy or other validation checks by rewriting them."
          },
          "safety_tolerance": {
            "x_ui_group": "advanced",
            "type": "string",
            "enum": [
              "1",
              "2",
              "3",
              "4",
              "5",
              "6"
            ],
            "default": "4",
            "description": "The safety tolerance level for content moderation. 1 is the most strict and 6 is the least strict."
          }
        },
        "additionalProperties": false
      }
