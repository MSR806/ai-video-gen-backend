{
  "models": [
    {
      "model_key": "nano_banana",
      "display_name": "Nano Banana",
      "provider": "fal",
      "media_type": "image",
      "enabled": true,
      "operations": [
        {
          "operation_key": "text_to_image",
          "endpoint_id": "fal-ai/nano-banana",
          "input_schema": {
            "type": "object",
            "required": [
              "prompt"
            ],
            "properties": {
              "prompt": {
                "type": "string",
                "description": "Text prompt used to generate the image."
              },
              "num_images": {
                "type": "integer",
                "default": 1
              },
              "aspect_ratio": {
                "type": "string",
                "enum": [
                  "1:1",
                  "9:16",
                  "16:9"
                ],
                "default": "16:9"
              },
              "seed": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        },
        {
          "operation_key": "image_to_image",
          "endpoint_id": "fal-ai/nano-banana/edit",
          "input_schema": {
            "type": "object",
            "required": [
              "prompt",
              "image_urls"
            ],
            "properties": {
              "prompt": {
                "type": "string",
                "description": "Text prompt used to edit the image."
              },
              "image_urls": {
                "type": "array",
                "items": {
                  "type": "string",
                  "format": "uri"
                }
              },
              "num_images": {
                "type": "integer",
                "default": 1
              },
              "aspect_ratio": {
                "type": "string",
                "enum": [
                  "1:1",
                  "9:16",
                  "16:9"
                ],
                "default": "1:1"
              },
              "seed": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        }
      ]
    },
    {
      "model_key": "veo_3_1",
