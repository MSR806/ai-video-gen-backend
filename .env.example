APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://app:app@db:5432/ai_video_gen
STORAGE_ENDPOINT=https://s3.us-east-1.amazonaws.com
STORAGE_PUBLIC_BASE_URL=https://dev.assets.mindumpai.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=mindumpai-user-media-dev
STORAGE_REGION=us-east-1
STORAGE_SECURE=true
VIDEO_THUMBNAIL_FFMPEG_BIN=ffmpeg
MAX_UPLOAD_SIZE_MB=50
FAL_API_KEY=
GENERATION_DEFAULT_PROVIDER=fal
GENERATION_WEBHOOK_PUBLIC_BASE_URL=http://localhost:8000
GENERATION_WEBHOOK_TOKEN=
GENERATION_STATUS_RECONCILE_AFTER_SECONDS=20
GENERATION_RESULT_MAX_DOWNLOAD_MB=25
GENERATION_REGISTRY_CACHE_TTL_SECONDS=300
